rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica si el usuario autenticado pertenece al negocio del documento
    // (app de un solo usuario: el negocio siempre es el propio uid)
    function canAccessBusiness(businessUid) {
      return request.auth != null && request.auth.uid == businessUid;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Escritura: solo el propio documento, con campos protegidos
      allow write: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['plan', 'uid', 'email', 'stripeCustomerId']);
      // Creación inicial (registro): el usuario solo puede crear su propio doc.
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['stripeCustomerId'])
        && (!request.resource.data.keys().hasAll(['plan']) || request.resource.data.plan == 'free');
    }

    // ── Pedidos ───────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Clientes ──────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Productos ─────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Etiquetas ─────────────────────────────────────────────────────────────
    match /labels/{labelId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Contadores de folios ───────────────────────────────────────────────────
    match /orderCounters/{counterId} {
      allow read, write: if request.auth != null &&
        counterId.matches(request.auth.uid + '_.*');
    }

    // ── Resultados de moderación de imágenes ──────────────────────────────────
    // Solo el Admin SDK (Cloud Function) puede crear/actualizar.
    // El propietario puede leer (incluso antes de que exista el doc) y borrar su resultado.
    match /moderatedImages/{docId} {
      allow read: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null &&
        resource != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Mensajes de soporte ────────────────────────────────────────────────────
    match /supportMessages/{msgId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Rate limit de soporte ─────────────────────────────────────────────────
    match /supportRateLimits/{docId} {
      allow read, write: if request.auth != null &&
        docId.matches(request.auth.uid + '_.*');
    }
  }
}
