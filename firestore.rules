rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Obtiene los datos del usuario autenticado
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica si el usuario autenticado es administrador
    function isAdmin() {
      return getUserData().role == 'admin';
    }

    // Retorna el UID del negocio: para admin es su propio UID, para empleado es negocioUid
    function getBusinessUid() {
      let u = getUserData();
      return (u.keys().hasAll(['negocioUid']) && u.negocioUid != null)
        ? u.negocioUid
        : request.auth.uid;
    }

    // Verifica si el usuario autenticado pertenece al negocio del documento
    function canAccessBusiness(businessUid) {
      return request.auth != null && getBusinessUid() == businessUid;
    }

    // ── Usuarios ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Lectura: propio documento, o admin (rol verificado) leyendo a sus empleados
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.negocioUid == request.auth.uid)
      );
      // Escritura: solo el propio documento, con campos protegidos
      allow write: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['plan', 'role', 'negocioUid', 'uid', 'email', 'username', 'numeroEmpleado', 'stripeCustomerId']);
      // Creación inicial (registro): el usuario solo puede crear su propio doc.
      // Se bloquea negocioUid y role para que nadie pueda auto-asignarse acceso
      // a otro negocio ni elevarse permisos en el momento del registro.
      // Los miembros son creados por Cloud Functions (Admin SDK), que bypasea estas reglas.
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['negocioUid', 'stripeCustomerId', 'numeroEmpleado', 'username'])
        && (!request.resource.data.keys().hasAll(['role']) || request.resource.data.role == 'admin')
        && (!request.resource.data.keys().hasAll(['plan']) || request.resource.data.plan == 'free');
    }

    // ── Pedidos ───────────────────────────────────────────────────────────────
    match /pedidos/{pedidoId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Clientes ──────────────────────────────────────────────────────────────
    match /clientes/{clienteId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Productos ─────────────────────────────────────────────────────────────
    match /productos/{productoId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Etiquetas ─────────────────────────────────────────────────────────────
    match /etiquetas/{etiquetaId} {
      allow read, update, delete: if canAccessBusiness(resource.data.userId);
      allow create: if canAccessBusiness(request.resource.data.userId);
    }

    // ── Contadores de folios ───────────────────────────────────────────────────
    match /pedidoCounters/{counterId} {
      allow read, write: if request.auth != null &&
        counterId.matches(getBusinessUid() + '_.*');
    }

    // ── Resultados de moderación de imágenes ──────────────────────────────────
    // Solo el Admin SDK (Cloud Function) puede crear/actualizar.
    // El propietario puede leer (incluso antes de que exista el doc) y borrar su resultado.
    match /imagenModerada/{docId} {
      allow read: if request.auth != null &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null &&
        resource != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Mensajes de soporte ────────────────────────────────────────────────────
    match /soporte/{msgId} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Rate limit de soporte ─────────────────────────────────────────────────
    match /soporteRateLimit/{docId} {
      allow read, write: if request.auth != null &&
        docId.matches(request.auth.uid + '_.*');
    }
  }
}
